# ============================================================================
# AI Night Shift — Configuration
# Copy this to config.env and adjust values to your setup
#
# Alternatively, use config.yml (YAML format) — see config.yml.example
# If both exist, config.yml takes precedence.
# ============================================================================

# ── General ──
NIGHT_SHIFT_DIR="${HOME}/ai-night-shift"
AGENT_NAME="my-agent"

# ── Agent Adapter ──
# Which AI CLI to use: claude-code, codex-cli, aider, or custom
AGENT_ADAPTER=claude-code

# Agent binary path (leave empty to use adapter default)
# AGENT_BIN=claude

# ── Night Shift Settings ──
MAX_ROUNDS=5
WINDOW_HOURS=6
ROUND_TIMEOUT=9000          # seconds per round (2.5h)
RATE_LIMIT_WAIT=3600        # seconds to wait on rate limit
SHUTDOWN_BUFFER=300          # seconds buffer before window end

# ⚠️  WARNING: Set to "true" ONLY if you fully understand the risks.
# This gives Claude Code unrestricted permissions (file I/O, shell commands).
# Recommended: keep "false" and use allowlist-based permissions instead.
SKIP_PERMISSIONS=false

# ── Claude Code Advanced ──
# CLAUDE_MODEL=claude-sonnet-4-6    # Model to use
# CLAUDE_MAX_TURNS=50                # Max conversation turns per round
# CLAUDE_ALLOWED_TOOLS="Read,Edit,Write,Bash,Grep,Glob"  # Restrict tool access
# CLAUDE_CONTINUE=false              # Resume previous session between rounds
# CLAUDE_SYSTEM_PROMPT=""            # Custom system prompt

# ── Gemini Module ──
GEMINI_BIN=gemini

# ── Project Directory ──
# Set this to auto-detect project settings (.nightshift.yml) and enable
# project-aware features (context injection, test verification, PR workflow).
# PROJECT_DIR="${HOME}/my-project"

# ── Multi-Project Rotation ──
# Comma-separated list of project directories. The runner will rotate
# between projects each round based on priority scoring.
# PROJECT_DIRS="${HOME}/project-a,${HOME}/project-b,${HOME}/project-c"

# ── Git Workflow ──
# GIT_WORKFLOW=feature-branch       # feature-branch, task-branch, or trunk-based
# GIT_BASE_BRANCH=main              # Base branch for PRs
# GIT_PR_DRAFT=true                 # Create PRs as drafts
# GIT_BRANCH_PREFIX=nightshift      # Branch name prefix

# ── Guardrails ──
# MAX_LINES_CHANGED=500             # Max lines changed per round
# MAX_FILES_CHANGED=20              # Max files changed per round
# GUARDRAIL_ACTION=warn             # warn, block, or revert

# ── Reporting (Optional) ──
# Uncomment and fill in to enable Telegram notifications
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# ── Task Management (Optional) ──
# Uncomment the tool you use
# TASK_TOOL="github"        # gh issue
# TASK_TOOL="linear"        # Linear API (requires LINEAR_API_KEY)
# TASK_TOOL="file"          # tasks.md

# ── Code Review Plugin ──
# REVIEWER_CLI=gemini                # Which CLI to use for post-shift review
# REVIEW_DIFF_LIMIT=500              # Max lines of diff to review

# ── CI Feedback Plugin ──
# CI_FEEDBACK_WAIT=60                # Seconds to wait for CI to start
# CI_FEEDBACK_TIMEOUT=600            # Max seconds to wait for CI
# CI_FEEDBACK_RETRY=false            # Auto-create fix task on failure

# ── CLAUDE.md Generator Plugin ──
# CLAUDEMD_OVERWRITE=false           # Regenerate CLAUDE.md each shift
# CLAUDEMD_TARGET=.                  # Target project directory

# ── Verification ──
# VERIFY_TIMEOUT=300                 # Timeout for test/build/lint (seconds)
# VERIFY_REVERT_ON_FAIL=false        # Revert last commit if tests fail
