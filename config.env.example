# ============================================================================
# AI Night Shift — Configuration
# Copy this to config.env and adjust values to your setup
# ============================================================================

# ── General ──
NIGHT_SHIFT_DIR="${HOME}/ai-night-shift"
AGENT_NAME="my-agent"

# ── Claude Code Module ──
CLAUDE_BIN=claude
MAX_ROUNDS=5
WINDOW_HOURS=6
ROUND_TIMEOUT=9000          # seconds per round (2.5h)
RATE_LIMIT_WAIT=3600        # seconds to wait on rate limit
SHUTDOWN_BUFFER=300          # seconds buffer before window end

# ── Gemini Module ──
GEMINI_BIN=gemini

# ── Reporting (Optional) ──
# Uncomment and fill in to enable Telegram notifications
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# ── Task Management (Optional) ──
# Uncomment the tool you use
# TASK_TOOL="linear"        # linear_tool.py
# TASK_TOOL="github"        # gh issue
# TASK_TOOL="file"          # tasks.md

# ── Project Directories (for git-related plugins) ──
# PROJECT_DIRS="${HOME}/projects"
